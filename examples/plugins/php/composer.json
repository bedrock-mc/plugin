{
  "name": "dragonfly/php-plugin-example",
  "description": "Example PHP plugin for Dragonfly using gRPC",
  "type": "project",
  "license": "MIT",
  "repositories": [
    {
      "type": "path",
      "url": "../../../packages/php",
      "options": {
        "symlink": true
      }
    }
  ],
  "require": {
    "php": ">=8.1",
    "dragonfly-plugins/plugin-sdk": "dev-main",
    "grpc/grpc": "^1.82.0",
    "google/protobuf": "^4.33.6"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "ExamplePhp\\": "src/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
